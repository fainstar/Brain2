PROJECT_NAME=second-brain

# Backend
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
BACKEND_DATA_DIR=/app/data

# LM Studio (OpenAI-compatible API)
LLM_BASE_URL=http://APIAPIAPI:1234/v1
LLM_API_KEY=APIKEY-APIKEY-APIKEY
LLM_CHAT_MODEL=qwen/qwen3-14b
LLM_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_TIMEOUT_SECONDS=60

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=brain_notes

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_to_a_strong_password
NEO4J_DATABASE=neo4j

# Optional: in-memory mode for local debug/tests
USE_IN_MEMORY=false
